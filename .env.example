# =============================================================================
# Assistant — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables provide secrets, credentials, and deployment-specific identity
# that override defaults from config/agent.yaml at runtime.
#
# Override precedence (highest wins):
#   1. Environment variable (this file, via docker-compose)
#   2. config/agent.yaml (tracked operational defaults)
#   3. Code-level fallback defaults
#
# =============================================================================


# =============================================================================
# REQUIRED — The system will not start without these
# =============================================================================

# PostgreSQL password. Used to build the database connection URL.
# ⚠️  You MUST change this before starting the stack. The application will log
#     a warning at startup if the placeholder value is still in use.
#     Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE-WITH-A-STRONG-PASSWORD

# OpenRouter API key for LLM access. Required for task processing.
OPENROUTER_API_KEY=


# =============================================================================
# AGENT IDENTITY
# =============================================================================
# These override agent.identity.name / agent.identity.email in YAML.
# Leave blank to use YAML defaults. If YAML is also blank:
#   - Name falls back to capitalized app name ("Assistant")
#   - Email falls back to SMTP_FROM → SMTP_USERNAME → "assistant@local"

AGENT_NAME=
AGENT_EMAIL=


# =============================================================================
# ADMIN & ORGANIZATION
# =============================================================================
# Admin receives approval requests and system notifications.
# ADMIN_EMAIL is required for core operation (approval emails go here).

ADMIN_NAME=
ADMIN_EMAIL=

# Organization identity for autonomous-agent disclosure footers.
# ORG_NAME appears in external email footers.
# ORG_SECURITY_EMAIL provides a contact for recipients.
# ORG_INTERNAL_EMAIL_DOMAINS (comma-separated) — recipients on these domains
# are considered internal and do not receive disclosure footers.
ORG_NAME=
ORG_SECURITY_EMAIL=
ORG_INTERNAL_EMAIL_DOMAINS=


# =============================================================================
# EMAIL — Required for email-driven operation
# =============================================================================
# Without IMAP settings, the agent operates in dashboard-only mode.
# Without SMTP settings, the agent cannot send email (approvals, replies, etc).
#
# For dashboard-only jobs, at minimum set SMTP_HOST, SMTP_PORT, and SMTP_FROM
# so the agent can send approval requests to the admin.

IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_ARCHIVE_FOLDER=Archive
IMAP_SENT_FOLDER=Sent

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=


# =============================================================================
# EMAIL SAFETY GUARDRAILS
# =============================================================================
# EMAIL_ALLOWED_RECIPIENT_DOMAINS (comma-separated) — only these domains can
# receive outbound email. Admin email is always allowed regardless.
# EMAIL_ACTIONABLE_SENDERS (comma-separated) — only these senders can create
# new jobs via inbound email. Replies to open jobs still work from anyone.

EMAIL_ALLOWED_RECIPIENT_DOMAINS=
EMAIL_ACTIONABLE_SENDERS=


# =============================================================================
# CALENDAR (optional)
# =============================================================================
# CalDAV credentials for the configured sync tool (vdirsyncer).
# These are NOT mapped into agent.yaml config — they are consumed directly
# by the sync command inside the container.
# Leave blank to keep calendar features disabled.

CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=


# =============================================================================
# AGENT BEHAVIOR — Override operational defaults from config/agent.yaml
# =============================================================================
# These let you tune common settings without editing the YAML file.
# Leave blank to use the defaults from config/agent.yaml.

# Timezone for scheduling, reminders, and timestamps (IANA format).
# Default: UTC
AGENT_TIMEZONE=

# Primary and fallback LLM models (OpenRouter model identifiers).
# Default: anthropic/claude-sonnet-4.6 / openai/gpt-5.4
AGENT_LLM_MODEL=
AGENT_LLM_FALLBACK_MODEL=

# Daily spend cap in USD. Agent stops processing when exceeded.
# Default: 10.00
AGENT_MAX_DAILY_COST_USD=

# Maximum outbound emails per hour (rate limit).
# Default: 10
AGENT_MAX_EMAILS_PER_HOUR=

# How often to poll IMAP for new messages (seconds).
# Default: 60
AGENT_IMAP_POLL_INTERVAL=

# Calendar integration. Set to true to enable, plus provide CALDAV_* above.
# Default: false
CALENDAR_ENABLED=

# Calendar timezone (IANA format). Falls back to AGENT_TIMEZONE if blank.
CALENDAR_TIMEZONE=


# =============================================================================
# DEPLOYMENT — Docker Compose publishing & scaling
# =============================================================================
# These are consumed by docker-compose.yml directly (not by the application).

# Dashboard host publishing:
# - 127.0.0.1 restricts the dashboard to this machine only.
# - Set to the server's LAN IP (e.g. 192.168.1.50) to allow LAN access
#   without publishing on every interface.
AGENT_API_PUBLISHED_HOST=127.0.0.1
AGENT_API_PUBLISHED_PORT=8000

# Public URL used in admin emails and generated links.
# Overrides agent.app.base_url from YAML. Leave blank to use YAML default.
AGENT_APP_BASE_URL=http://localhost:8000

# API documentation exposure. Both are off by default — they expose a full
# enumeration of all API endpoints and should remain disabled unless you are
# developing locally and have no external network exposure.
AGENT_API_DOCS_ENABLED=false
AGENT_API_OPENAPI_ENABLED=false


# =============================================================================
# SECURITY — See docs/security.md for the full security guide
# =============================================================================

# Enable/disable the browser UIs. Setting these to false makes /admin and
# /workspace return 404. The underlying /api/* endpoints remain available.
# NOTE: this is not authentication — it only hides the browser interfaces.
# For true protection on public servers use a reverse proxy with auth.
# Both are disabled by default. Enable them only when you need the browser UI
# on a network you control (the port defaults to 127.0.0.1 — localhost only).
AGENT_API_DASHBOARD_ENABLED=false
AGENT_API_WORKSPACE_ENABLED=false

# Maximum size in bytes for a single workspace upload. Requests exceeding this
# are rejected with HTTP 413. Default: 524288000 (500 MB).
AGENT_API_MAX_UPLOAD_BYTES=


# =============================================================================
# SCALING
# =============================================================================

# Number of concurrent task-agent workers for parallel job processing.
TASK_AGENT_WORKERS=1
